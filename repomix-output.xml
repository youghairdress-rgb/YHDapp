    color: var(--white-color);
    padding: 1.25rem 1.5rem;
    text-align: center;
    border-radius: 12px;
    /* ▼▼▼ 修正: ナビ追加のため、ヘッダー下のマージンを減らす ▼▼▼ */
    margin-bottom: 1rem;
    /* ▲▲▲ 修正ここまで ▲▲▲ */
    box-shadow: 0 4px 12px rgba(0, 171, 181, 0.2);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
}

header h1 {
    margin: 0;
    font-size: 1.5rem;
}

.back-button {
    position: absolute;
    top: 50%;
    left: 1.5rem;
    transform: translateY(-50%);
    color: var(--white-color);
    text-decoration: none;
    font-size: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

/* ▼▼▼ 追加: クイックナビゲーション ▼▼▼ */
.quick-nav-menu {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    padding: 0.75rem;
    /* カードのpaddingを少し減らす */
