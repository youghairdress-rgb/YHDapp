<file path="public/diagnosis/css/style.css">
/* style.css - Comprehensive Visual Styles for Landscape UI */

/* Variables & Global (Inherited from base.css) */
body {
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    font-size: 20px;
    /* Scaled up for 23-inch monitor */
    overflow: hidden;
}

/* --- Branding & Common Typography --- */
#phase1 {
    background: linear-gradient(135deg, #e0f2fe 0%, #f0fdfa 50%, #fff 100%);
}

.p1-text-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    /* Ensure left-alignment for all children in the right zone */
    justify-content: center;
}

.logo-text-1 {
    font-size: 100px;
    background: linear-gradient(to right, var(--primary-color), var(--dark-color));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 900;
    margin: 0;
}

.logo-text-2 {
    font-size: 54px;
    color: var(--text-color);
    margin: 10px 0 10px;
}

.user-greeting {
    font-size: 32px;
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: 25px;
    text-align: left;
    /* Alignment fix */
}

.p1-description {
    font-size: 24px;
    line-height: 1.6;
    color: var(--text-color-light);
    margin-bottom: 50px;
}

/* --- Results & Proposal Sections --- */
.result-section,
.proposal-section {
    background: #fff;
    border-radius: 32px;
    padding: 40px;
    margin-bottom: 40px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
}

.result-title,
.proposal-title {
    font-size: 32px;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 15px;
    margin-top: 0;
    margin-bottom: 30px;
    color: var(--text-color);
}

.result-icon,
.proposal-icon {
    width: 48px;
    height: 48px;
}

.result-grid,
.proposal-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
}

.result-item,
.proposal-item {
    padding: 24px;
    background: #f8fafc;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.result-item-label,
.proposal-item-label {
    font-size: 18px;
    font-weight: 700;
    color: var(--primary-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.result-item-value,
.proposal-item-value {
    font-size: 26px;
    font-weight: 600;
    color: var(--text-color);
}

.top-stylist-comment {
    background: #fff8f1;
    padding: 40px;
    border-radius: 32px;
    border-left: 12px solid #f59e0b;
    font-size: 28px;
    line-height: 1.6;
    color: #92400e;
}

/* Phase 5 Special Components */
.proposal-card {
    padding: 24px;
    background: #f8fafc;
    border-radius: 20px;
    border: 1px solid #e2e8f0;
    transition: all 0.3s ease;
}

.proposal-card strong {
    display: block;
    font-size: 24px;
    font-weight: 800;
    margin-bottom: 12px;
    color: var(--primary-color);
}

.proposal-card p {
    font-size: 20px;
    margin: 0;
    color: var(--text-color-light);
    line-height: 1.5;
}

/* Phase 5: Proposal Items (Maximum Density for 3-Column) */
.proposal-grid-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.proposal-item {
    padding: 6px 12px;
    /* Reduced from 10px 15px */
    background: #fff;
    border-radius: 8px;
    border: 1px solid #f1f5f9;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.best-colors-row {
    display: flex;
    justify-content: space-around;
    align-items: center;
    gap: 12px;
    padding: 5px 0;
    /* Reduced */
}

.color-swatch-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
}

.color-swatch-circle {
    width: 50px;
    /* Reduced from 60px */
    height: 50px;
    border-radius: 50%;
    border: 2px solid #fff;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.08);
}

.color-swatch-name {
    font-size: 13px;
    font-weight: 700;
}

.makeup-item-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 10px;
    /* Reduced */
    background: #fff;
    border-radius: 6px;
    margin-bottom: 3px;
}

.makeup-label {
    font-size: 14px;
    font-weight: 700;
    color: var(--primary-color);
}

.makeup-value {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-color);
    padding-left: 4ch;
    /* Shift right by 4 characters */
}

.stylist-advice-container {
    background: #fff;
    border-radius: 12px;
    padding: 1vh 1.2vw;
    border: 1px dashed #cbd5e1;
    height: auto;
    min-height: 40px;
}

#top-stylist-comment-text {
    font-size: clamp(14px, 1.8vh, 18px);
    /* Increased from clamp(12px, 1.5vh, 15px) */
    line-height: 1.4;
    color: #334155;
    margin: 0;
}

/* --- Phase 6: Selection --- */
.phase6-layout-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    height: 100%;
    align-items: stretch;
}

.p6-col-style,
.p6-col-color,
.p6-col-action {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: 100%;
}

.scroll-y {
    overflow-y: auto;
    flex: 1;
    padding-right: 15px;
}

.refinement-title {
    background-color: var(--primary-color-lighter);
    padding: 20px 30px;
    border-radius: 20px;
    margin-bottom: 25px;
    font-size: 28px;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 15px;
}

/* Radio Options as Modern Cards */
.radio-option {
    margin-bottom: 20px;
    position: relative;
    transition: transform 0.2s;
}

.radio-option input[type="radio"] {
    display: none;
}

.radio-option label {
    display: block;
    padding: 25px;
    background: #fff;
    border: 2px solid #e2e8f0;
    border-radius: 20px;
    cursor: pointer;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.4;
    transition: all 0.3s ease;
}

.radio-option input[type="radio"]:checked+label {
    border-color: var(--primary-color);
    background-color: var(--primary-color-lighter);
    box-shadow: 0 8px 20px rgba(10, 186, 181, 0.1);
}

.radio-option:hover {
    transform: translateY(-2px);
}

/* --- Phase 7: Canvas Rendering --- */
#phase6-canvas {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
}

.adjustment-controls {
    display: flex;
