}

.result-item-value {
  font-size: clamp(13px, 1.8vh, 18px) !important;
  font-weight: 500 !important;
  color: #1e293b !important;
  line-height: 1.2 !important;
  /* Tight line height */
  text-align: left !important;
}

.p4-footer {
  grid-column: 1 / span 2;
  margin-top: 1vh;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 30px;
}

/* Specific wide buttons for Phase 4 footer to ensure perfect alignment */
.btn-outline-wide {
  background-color: #fff;
  color: var(--primary-color);
  font-size: 24px;
  font-weight: 700;
  padding: 18px 60px;
  border-radius: 16px;
  border: 1px solid #94a3b8;
  cursor: pointer;
  min-width: 350px;
  display: flex;
  justify-content: center;
  align-items: center;
