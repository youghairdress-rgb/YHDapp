      <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-gray-800">キーワードを選択</h2>
          <button onclick="resetTags()" class="text-base text-gray-400 hover:text-gray-600 flex items-center gap-1">
            <i class="fa-solid fa-rotate-right"></i> リセット
          </button>
        </div>
        <p class="text-base text-gray-500 mb-8">
          希望するイメージに近いタグをタップしてください。プロンプトが自動で生成されます。
        </p>

        <div id="categories-container" class="space-y-8">
          <!-- Categories will be rendered here by JS -->
        </div>
      </div>
    </div>

    <!-- Right/Bottom: Result Area -->
    <div class="lg:w-1/3 w-full">
      <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 sticky top-40 flex flex-col gap-6">

        <!-- Output 1: Japanese Record -->
        <div>
          <h2 class="text-xl font-bold text-gray-800 mb-3 flex items-center gap-2">
            <i class="fa-solid fa-file-medical text-yhd-primary"></i> カルテ用（日本語）
          </h2>
          <div class="relative">
            <textarea id="prompt-textarea-ja" readonly placeholder="タグを選択すると、ここにカルテ用の日本語テキストが生成されます。"
              class="w-full h-48 p-4 bg-gray-50 border border-gray-200 rounded-lg text-base text-gray-700 focus:outline-none resize-none leading-relaxed"></textarea>
          </div>
          <button id="save-karte-btn" onclick="saveToKarte()" disabled
            class="mt-3 w-full py-3 px-6 rounded-lg text-base font-bold flex items-center justify-center gap-2 transition-all bg-yhd-primary text-white shadow-md shadow-teal-500/20 hover:bg-yhd-dark disabled:opacity-50 disabled:cursor-not-allowed">
            <i class="fa-solid fa-save"></i> カルテに保存
          </button>
        </div>

        <!-- Output 2: English AI Prompt -->
        <div>
          <h2 class="text-xl font-bold text-gray-800 mb-3 flex items-center gap-2">
            <i class="fa-solid fa-robot text-yhd-primary"></i> AI入力用プロンプト（英語）
          </h2>
          <div class="relative">
            <textarea id="prompt-textarea-en" readonly placeholder="タグを選択すると、ここに画像生成AI向けの英語カンマ区切りタグが生成されます。"
              class="w-full h-48 p-4 bg-indigo-50 border border-indigo-100 rounded-lg text-base text-indigo-900 font-mono focus:outline-none resize-none leading-relaxed"></textarea>
          </div>

          <button id="copy-btn" onclick="copyPrompt()" disabled
            class="mt-4 w-full py-3 px-6 rounded-lg text-lg font-bold flex items-center justify-center gap-2 transition-all bg-gray-100 text-gray-400 cursor-not-allowed">
            <i class="fa-regular fa-copy"></i> 英語プロンプトをコピー
          </button>
          <p class="text-xs text-gray-500 mt-3 text-center">
            コピーした英語タグを、各アプリの自由入力欄にペーストしてご利用ください。
          </p>
        </div>

      </div>
    </div>
  </main>

  <script type="module">
    import { db } from '../admin/firebase-init.js';
    import { collection, addDoc, serverTimestamp } from 'firebase/firestore';

    // データ定義
    const APP_MODES = {
      DIAGNOSIS: 'diagnosis',
      HAIR_COLOR: 'hair_color',
    };

    const promptDictionary = {
      length: { 'ベリーショート': 'pixie cut, very short hair, cropped hair', 'ショート': 'short hair, neat short haircut', 'ボブ': 'bob cut hair, chin-length hair', 'ミディアム': 'medium length hair, shoulder-length hair', 'セミロング': 'medium-long hair, collarbone-length hair', 'ロング': 'long hair, flowing long hair', 'スーパーロング': 'very long hair, waist-length hair' },
      taste: { 'フェミニン': 'feminine style, soft and elegant, girly', 'クール': 'cool style, sharp and edgy look, stylish', 'カジュアル': 'casual style, everyday look, relaxed vibe', 'エレガント': 'elegant style, sophisticated, graceful look', '韓国風（ヨシンモリ）': 'korean hairstyle, goddess waves, soft large curls, elegant korean beauty', 'ワンホン（中華風）': 'wanghong styling, chinese influencer style, voluminous glamorous hair, luxurious', 'ナチュラル': 'natural style, effortless beauty, simple and clean', '大人可愛い': 'mature yet cute, sophisticated but sweet, adult kawaii', 'モード': 'mode style, high fashion, avant-garde, chic', 'ハンサム': 'handsome look, boyish charm, sharp silhouette, androgynous style', '抜け感・こなれ感': 'effortless style, natural movement, relaxed hair styling, lived-in look' },
      bangs: { '前髪あり': 'with bangs, front fringe', '前髪なし': 'no bangs, exposed forehead', 'シースルーバング': 'wispy bangs, thin fringe, see-through bangs, forehead slightly visible', '2wayバング': 'versatile bangs, lightly parted bangs', 'センターパート': 'center parting, middle part', 'おくれ毛・エギョモリ': 'face-framing layers, side wisps, korean side bangs, soft tendrils', 'かき上げバング': 'side-swept long bangs, brushed up bangs, voluminous root, swept back fringe', 'オン眉': 'short bangs, bangs above eyebrows, micro fringe', 'ワイドバング': 'wide bangs, extended fringe connecting to sides', 'フェイスレイヤー': 'face-framing layers, layers cut around the face, contoured face-framing', 'うざバング': 'long messy bangs, eye-grazing fringe, overgrown bangs' },
      texture: { 'ストレート': 'straight hair, sleek and smooth straight', 'ゆるふわウェーブ': 'loose soft waves, airy curls, gentle hair texture', '外ハネ': 'outward curled ends, flipped ends, playful movement', 'ウェット感（濡れ髪）': 'wet hair look, styling oil finish, sleek glossy texture', 'ひし形シルエット': 'diamond-shaped silhouette, voluminous sides with tapered ends', '切りっぱなし（ぷつんと）': 'blunt cut ends, straight cut bottom, sharp hair ends', 'くびれヘア': 'constricted silhouette, outward flipped ends with voluminous top, hourglass hair shape', '束感': 'textured hair bundles, defined strands, piecey texture', '無造作（ルーズ）': 'messy styling, tousled hair, bedhead look, unkempt texture', 'レイヤーカット': 'layered hair cut, feathered layers, dynamic hair flow', 'ウルフ': 'modern wolf cut hair, layered mullet style, shaggy layers', 'マッシュ': 'mushroom cut, rounded bowl-like silhouette, heavy top' },
      concerns: { '小顔に見せたい': 'face-framing for small face effect, flattering proportions', '丸顔をカバー': 'vertical silhouette, side-swept hair covering cheeks, elongating style', '面長をカバー': 'horizontal volume, side volume to balance face shape, fluffy sides', 'エラを隠したい': 'hair falling gracefully around jawline, face-framing layers covering jaw', 'ボリュームを出したい': 'voluminous hair, thick hair, lifted roots, bouncy texture', 'クセを抑えたい': 'smooth and controlled texture, frizz-free, sleek finish', '絶壁をカバー': 'rounded back of head, voluminous crown, beautifully shaped back profile', '骨格を補正したい': 'well-balanced head shape, perfectly contoured hair silhouette', '髪をきれいに見せたい': 'healthy looking hair, extremely beautiful hair texture, rich quality', '似合わせ重視': 'flattering cut, perfectly suited to face, highly attractive' },
      baseColor: { 'ブラウン系（ショコラ等）': 'chocolat brown hair, rich brown color, natural brunette', 'アッシュ・グレー系': 'ash grey hair, cool undertones, muted smoky tint', 'ピンク・レッド系（カシス等）': 'cassis pink hair, reddish undertones, soft berry tint', 'オレンジ系（アプリコット等）': 'apricot orange hair, warm copper tint, soft tangerine', 'ベージュ系（ミルクティー等）': 'milk tea beige hair, soft warm neutral, creamy blonde', 'グレージュ': 'greige hair, grayish beige tint, soft cool neutral', 'ブラック（暗髪）': 'natural black hair, dark hair, healthy dark tint', 'オリーブ・マット系': 'olive undertone hair, matte green tint, cool earth tone', 'ブルー・ネイビー系': 'blue-black hair, navy undertones, deep cool tint' },
      tone: { '4〜5トーン（地毛・黒髪）': 'level 5 dark tone hair, natural dark shade, barely tinted', '6〜7トーン（暗め・オフィスOK）': 'level 7 dark brown hair, subdued office-friendly color, deep shade', '8〜9トーン（中間・自然な明るさ）': 'level 9 medium tone hair, natural brightness, standard color level', '10〜12トーン（明るめ・ハイトーン）': 'level 12 light tone hair, bright hair color, high-tone', '13トーン以上（ブリーチ必須レベル）': 'level 14 very light hair, bleached base color, ultra high-tone' },
      design: { 'ワンカラー（全体染め）': 'solid hair color, even coloring, single tone all over', 'インナーカラー': 'inner color hair, peekaboo highlights, different color underneath', 'イヤリングカラー': 'earring color, inner color around ears, hidden ear highlights', 'ハイライト': 'highlighted hair, dimensional streaks, contrasting strands', 'シークレットハイライト': 'secret highlights, subtle micro-highlights, seamlessly blended streaks', 'グラデーション': 'ombre hair color, smooth color transition from roots to ends, gradient color', 'バレイヤージュ': 'balayage hair color, hand-painted highlights, dimensional root stretch', 'フェイスフレーミング': 'face-framing highlights, money piece hair, bright front strands', 'アンブレラカラー': 'umbrella color hair, lighter top layer covering darker underlayer, two-tone contrasting sections', '裾カラー': 'dip dye hair ends, colored hair tips, contrasting ends', 'ルーツカラー': 'roots color, contrasting root shadow, colored roots' },
      colorTexture: { '透明感': 'translucent hair color, soft diffused lighting, clear hair texture', 'ツヤ感': 'high specular highlights, healthy hair shine, glossy professional salon finish', 'くすみ感': 'muted hair color, smoky tint, desaturated matte finish', 'まろやか': 'mellow hair color, creamy and soft texture, smooth blended tone', '外国人風': 'westerner style hair, soft fine texture, dimensional western look', '艶髪': 'ultra-glossy hair, rich polished hair surface, silky shine', '色落ちも綺麗': 'vibrant long-lasting color, beautiful color presentation', '髪質改善カラー': 'perfectly healthy hair texture, incredibly smooth and nourished, damage-free look', '白髪ぼかし': 'seamlessly blended silver strands, high-dimensional gray blending, youthful appearance', 'ダメージレス': 'undamaged healthy hair, smooth cuticles, flawless texture' }
    };

    const CATEGORIES = {
      [APP_MODES.DIAGNOSIS]: [
        {
          id: 'length',
          title: 'レングス（長さ）',
          multiSelect: false,
          tags: [
            'ベリーショート',
            'ショート',
            'ボブ',
            'ミディアム',
            'セミロング',
            'ロング',
            'スーパーロング',
          ],
        },
        {
          id: 'taste',
          title: 'テイスト（雰囲気）',
          multiSelect: true,
          tags: [
            'フェミニン',
            'クール',
            'カジュアル',
            'エレガント',
            '韓国風（ヨシンモリ）',
            'ワンホン（中華風）',
            'ナチュラル',
            '大人可愛い',
            'モード',
            'ハンサム',
            '抜け感・こなれ感',
          ],
        },
        {
          id: 'bangs',
          title: '前髪・顔回り',
          multiSelect: true,
          tags: [
            '前髪あり',
            '前髪なし',
            'シースルーバング',
            '2wayバング',
            'センターパート',
            'おくれ毛・エギョモリ',
            'かき上げバング',
            'オン眉',
            'ワイドバング',
            'フェイスレイヤー',
            'うざバング',
          ],
        },
        {
          id: 'texture',
          title: 'スタイリング・質感・形',
          multiSelect: true,
          tags: [
            'ストレート',
            'ゆるふわウェーブ',
            '外ハネ',
            'ウェット感（濡れ髪）',
            'ひし形シルエット',
            '切りっぱなし（ぷつんと）',
            'くびれヘア',
            '束感',
            '無造作（ルーズ）',
            'レイヤーカット',
            'ウルフ',
            'マッシュ',
          ],
        },
        {
          id: 'concerns',
          title: 'カバーしたい悩み',
          multiSelect: true,
          tags: [
            '小顔に見せたい',
            '丸顔をカバー',
            '面長をカバー',
            'エラを隠したい',
            'ボリュームを出したい',
            'クセを抑えたい',
            '絶壁をカバー',
            '骨格を補正したい',
            '髪をきれいに見せたい',
            '似合わせ重視',
          ],
        },
      ],
      [APP_MODES.HAIR_COLOR]: [
        {
          id: 'baseColor',
          title: 'ベースカラー系統',
          multiSelect: true,
          tags: [
            'ブラウン系（ショコラ等）',
            'アッシュ・グレー系',
            'ピンク・レッド系（カシス等）',
            'オレンジ系（アプリコット等）',
            'ベージュ系（ミルクティー等）',
            'グレージュ',
            'ブラック（暗髪）',
            'オリーブ・マット系',
            'ブルー・ネイビー系',
          ],
        },
        {
          id: 'tone',
          title: 'トーン（明るさ）',
          multiSelect: false,
          tags: [
            '4〜5トーン（地毛・黒髪）',
            '6〜7トーン（暗め・オフィスOK）',
            '8〜9トーン（中間・自然な明るさ）',
            '10〜12トーン（明るめ・ハイトーン）',
            '13トーン以上（ブリーチ必須レベル）',
          ],
        },
        {
          id: 'design',
          title: 'デザインカラー',
          multiSelect: true,
          tags: [
            'ワンカラー（全体染め）',
            'インナーカラー',
            'イヤリングカラー',
            'ハイライト',
            'シークレットハイライト',
            'グラデーション',
            'バレイヤージュ',
            'フェイスフレーミング',
            'アンブレラカラー',
            '裾カラー',
            'ルーツカラー',
          ],
        },
        {
          id: 'colorTexture',
          title: 'カラーの質感・テーマ',
          multiSelect: true,
          tags: [
            '透明感',
            'ツヤ感',
            'くすみ感',
            'まろやか',
            '外国人風',
            '艶髪',
            '色落ちも綺麗',
            '髪質改善カラー',
            '白髪ぼかし',
            'ダメージレス',
          ],
        },
      ],
    };

    // 状態管理
    let currentMode = APP_MODES.DIAGNOSIS;
    let selectedTags = {};
    let generatedJaText = '';
    let generatedEnText = '';

    // DOM要素
    const container = document.getElementById('categories-container');
    const promptTextareaJa = document.getElementById('prompt-textarea-ja');
    const promptTextareaEn = document.getElementById('prompt-textarea-en');
    const copyBtn = document.getElementById('copy-btn');
    const btnDiagnosis = document.getElementById('btn-mode-diagnosis');
    const btnColor = document.getElementById('btn-mode-color');

    // モード切替
    function setMode(mode) {
      currentMode = mode;
      selectedTags = {};
      generatedJaText = '';
      generatedEnText = '';

      // タブの見た目更新
      if (mode === APP_MODES.DIAGNOSIS) {
        btnDiagnosis.className =
          'py-2 px-6 rounded-md text-base font-medium flex items-center justify-center gap-2 transition-all bg-white shadow-sm text-yhd-primary';
        btnColor.className =
          'py-2 px-6 rounded-md text-base font-medium flex items-center justify-center gap-2 transition-all text-gray-500 hover:text-gray-700 hover:bg-gray-200';
        promptTextareaJa.placeholder = 'タグを選択すると、ここにカルテ用の日本語テキストが生成されます。';
        promptTextareaEn.placeholder = 'タグを選択すると、ここに画像生成AI向けの英語カンマ区切りタグが生成されます。';
      } else {
        btnDiagnosis.className =
          'py-2 px-6 rounded-md text-base font-medium flex items-center justify-center gap-2 transition-all text-gray-500 hover:text-gray-700 hover:bg-gray-200';
        btnColor.className =
          'py-2 px-6 rounded-md text-base font-medium flex items-center justify-center gap-2 transition-all bg-white shadow-sm text-yhd-primary';
        promptTextareaJa.placeholder = 'タグを選択すると、ここにカルテ用の日本語テキストが生成されます。';
        promptTextareaEn.placeholder = 'タグを選択すると、画像生成AI向けに最適化された英語プロンプトが生成されます。';
      }

      renderCategories();
      updatePrompt();
    }
    window.setMode = setMode;

    // リセット
    function resetTags() {
      selectedTags = {};
      renderCategories();
      updatePrompt();
    }
    window.resetTags = resetTags;

    // タグクリック処理
    window.handleTagClick = function (categoryId, tag, isMultiSelect) {
      if (!selectedTags[categoryId]) {
        selectedTags[categoryId] = [];
      }

      const isSelected = selectedTags[categoryId].includes(tag);

      if (isMultiSelect) {
        if (isSelected) {
          selectedTags[categoryId] = selectedTags[categoryId].filter((t) => t !== tag);
        } else {
          selectedTags[categoryId].push(tag);
        }
      } else {
        selectedTags[categoryId] = isSelected ? [] : [tag];
      }

      renderCategories();
      updatePrompt();
    };

    // カテゴリとタグの描画
    function renderCategories() {
      container.innerHTML = '';
      const categories = CATEGORIES[currentMode];

      categories.forEach((category) => {
        const categoryDiv = document.createElement('div');
        categoryDiv.className = 'space-y-3';

        const multiSelectLabel = !category.multiSelect
          ? `<span class="text-xs text-gray-400 ml-2 font-normal">(1つだけ選択可)</span>`
          : '';

        let tagsHtml = category.tags
          .map((tag) => {
            const isSelected =
              selectedTags[category.id] && selectedTags[category.id].includes(tag);

            let baseClass =
              'px-6 py-3 rounded-full text-base font-medium transition-all duration-200 border outline-none cursor-pointer ';
            if (isSelected) {
              baseClass += 'bg-yhd-light border-yhd-primary text-yhd-dark shadow-sm';
            } else {
              baseClass +=
                'bg-white border-gray-200 text-gray-700 hover:border-gray-300 hover:bg-gray-50';
            }

            return `<button type="button" class="${baseClass}" onclick="handleTagClick('${category.id}', '${tag}', ${category.multiSelect})">${tag}</button>`;
          })
          .join('');

        categoryDiv.innerHTML = `
                    <h3 class="text-lg font-bold text-gray-800 border-l-4 border-yhd-primary pl-3">
                        ${category.title} ${multiSelectLabel}
                    </h3>
                    <div class="flex flex-wrap gap-4 mt-2">
                        ${tagsHtml}
                    </div>
                `;
        container.appendChild(categoryDiv);
      });
    }

    // プロンプト生成ロジック
    function updatePrompt() {
      const isEmpty = Object.keys(selectedTags).length === 0 || Object.values(selectedTags).every((arr) => arr.length === 0);

      if (isEmpty) {
        generatedJaText = '';
        generatedEnText = '';
      } else {
        let jaParts = [];
        let enParts = ['masterpiece', 'photorealistic', 'high quality salon photography'];

        // 共通：選択されているカテゴリとタグをループして翻訳を引く
        CATEGORIES[currentMode].forEach(category => {
          const tags = selectedTags[category.id] || [];
          if (tags.length > 0) {
            // 日本語カルテ用
            jaParts.push(`【${category.title}】 ${tags.join('、')}`);

            // 英語タグ用 (辞書から取得)
            tags.forEach(tag => {
              // category.id が辞書にあるか確認
              const dictCategory = promptDictionary[category.id];
              if (dictCategory && dictCategory[tag]) {
                enParts.push(dictCategory[tag]);
              } else {
                // 辞書に完全一致しない場合（予備）は日本語のまま（または無視）
                // 今回は無視するか、翻訳がない場合はそのまま入れるかを選択可能
              }
            });
          }
        });

        // テキストの結合
        generatedJaText = jaParts.join('\n');
        generatedEnText = enParts.join(', ');
      }

      // UI反映
      promptTextareaJa.value = generatedJaText;
      promptTextareaEn.value = generatedEnText;

      const saveKarteBtn = document.getElementById('save-karte-btn');

      if (generatedEnText) {
        copyBtn.disabled = false;
        copyBtn.className = 'mt-4 w-full py-3 px-6 rounded-lg text-lg font-bold flex items-center justify-center gap-2 transition-all bg-yhd-navy text-white hover:bg-gray-800 shadow-md';
        if (customerId) saveKarteBtn.disabled = false;
      } else {
        copyBtn.disabled = true;
        copyBtn.className = 'mt-4 w-full py-3 px-6 rounded-lg text-lg font-bold flex items-center justify-center gap-2 transition-all bg-gray-100 text-gray-400 cursor-not-allowed';
        saveKarteBtn.disabled = true;
      }
    }

    // コピー処理
    window.copyPrompt = async function () {
      if (!generatedEnText) return;
      const textToCopy = generatedEnText;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(textToCopy);
        } else {
          const textArea = document.createElement('textarea');
          textArea.value = textToCopy;
          textArea.style.position = 'fixed';
          textArea.style.left = '-999999px';
          textArea.style.top = '-999999px';
          document.body.appendChild(textArea);
          textArea.focus();
          textArea.select();
          document.execCommand('copy');
          textArea.remove();
        }

        // 成功UIの表示
        copyBtn.innerHTML = '<i class="fa-solid fa-check"></i> コピーしました！';
        copyBtn.className =
          'mt-6 w-full py-4 px-6 rounded-lg text-lg font-bold flex items-center justify-center gap-2 transition-all bg-green-500 text-white shadow-md';

        setTimeout(() => {
          copyBtn.innerHTML = '<i class="fa-regular fa-copy"></i> プロンプトをコピー';
          copyBtn.className =
            'mt-6 w-full py-4 px-6 rounded-lg text-lg font-bold flex items-center justify-center gap-2 transition-all bg-yhd-navy text-white hover:bg-gray-800 shadow-md';
        }, 2000);
      } catch (err) {
        console.error('Failed to copy text: ', err);
        alert('コピーに失敗しました。');
      }
    }

    // カルテ保存処理
    window.saveToKarte = async function () {
      if (!customerId || !generatedJaText) return;

      const saveBtn = document.getElementById('save-karte-btn');
      saveBtn.disabled = true;
      saveBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> 保存中...';

      try {
        await addDoc(collection(db, 'users', customerId, 'visitHistory'), {
          date: new Date().toISOString().split('T')[0], // YYYY-MM-DD
          title: 'プロンプトジェネレーター',
          kartePrompt: generatedJaText,
          createdAt: serverTimestamp()
        });

        saveBtn.innerHTML = '<i class="fa-solid fa-check"></i> 保存しました';
        saveBtn.className = 'mt-3 w-full py-3 px-6 rounded-lg text-base font-bold flex items-center justify-center gap-2 transition-all bg-green-500 text-white shadow-md shadow-green-500/20';

        setTimeout(() => {
          saveBtn.innerHTML = '<i class="fa-solid fa-save"></i> カルテに保存';
          saveBtn.className = 'mt-3 w-full py-3 px-6 rounded-lg text-base font-bold flex items-center justify-center gap-2 transition-all bg-yhd-primary text-white shadow-md shadow-teal-500/20 hover:bg-yhd-dark';
          saveBtn.disabled = false;
        }, 2000);
      } catch (err) {
        console.error('Failed to save to karte: ', err);
        alert('カルテへの保存に失敗しました。');
        saveBtn.innerHTML = '<i class="fa-solid fa-save"></i> カルテに保存';
        saveBtn.disabled = false;
      }
    }

    // 初期化処理
    let customerId = null;
    let customerName = null;

    function init() {
      // Parse URL parameters
      const urlParams = new URLSearchParams(window.location.search);
      customerId = urlParams.get('customerId');
      customerName = urlParams.get('customerName');

      if (customerName) {
        const displaySpan = document.getElementById('customer-name-display');
        displaySpan.textContent = `${customerName} 様`;
        displaySpan.style.display = 'inline';
      }

      setMode(currentMode);
    }
    window.init = init;

    // 実行
    init();
  </script>
</body>

