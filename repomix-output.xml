<file path="public/mypage.html">
<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>マイページ | YOU-G HAIR Dress</title>
    <link rel="icon" href="./img/YHDlogo2.png" type="image/png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="user-style.css">
</head>

<body>
    <div id="app-container">
        <header class="user-header">
            <div class="logo">
                <img src="./img/YHDlogo2.png" alt="YHD Logo">
            </div>
            <h1>マイページ</h1>
        </header>

        <main id="mypage-content" style="display: none;">
            <div class="mypage-container">
                <!-- ユーザー基本情報 (ヘッダー風デザイン) -->
                <section class="mypage-section">
                    <div class="user-info-card"
                        style="padding: 20px; background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <div
                            style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 15px;">
                            <div>
                                <p style="font-size: 0.9rem; color: #666; margin-bottom: 4px;">ようこそ</p>
                                <h2 style="font-size: 1.6rem; font-weight: bold; color: #333; margin: 0;">
                                    <span id="user-name">読み込み中...</span> 様
                                </h2>
                            </div>
                            <!-- 画像アップロードボタン (お名前の横) -->
                            <div style="flex-shrink: 0;">
                                <input type="file" id="user-image-upload" accept="image/*" class="hidden"
                                    style="display:none;">
                                <button id="trigger-upload-btn" class="button-primary"
                                    style="width: auto; padding: 10px 20px; font-size: 0.9rem; border-radius: 30px; background: #0ABAB5; display: flex; align-items: center; gap: 6px;">
                                    <i class="fa-solid fa-cloud-arrow-up"></i> 画像をアップロード
                                </button>
                                <div id="upload-status-area" class="hidden"
                                    style="font-size: 0.75rem; color: #0ABAB5; text-align: center; margin-top: 4px; font-weight: bold; display: none;">
                                    送信中...
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- タブ切り替え -->
                <div class="mypage-tabs">
                    <button class="tab-button active" data-tab="history">予約履歴</button>
                    <button class="tab-button" data-tab="gallery">ギャラリー</button>
                </div>

                <!-- 予約履歴パネル -->
                <div id="history-panel" class="tab-content-panel active">
                    <div id="reservation-history-list">
                        <p class="loading-msg">履歴を読み込み中...</p>
                    </div>
                </div>

                <!-- ギャラリーパネル -->
                <div id="gallery-panel" class="tab-content-panel">
                    <div id="gallery-container">
                        <p class="loading-msg">写真を読み込み中...</p>
                    </div>
                </div>
            </div>
        </main>

        <div id="loading-container" style="display: flex;">
            <div class="spinner"></div>
            <p id="loading-text">読み込み中...</p>
        </div>
        <div id="registration-container" style="display: none;">
        </div>
    </div>

    <!-- 画像ビューア (ギャラリー用) -->
    <div id="image-viewer" class="image-viewer">
        <span class="close-viewer">&times;</span>
        <img class="image-viewer-content" id="viewer-img">
        <div class="viewer-actions" style="margin-top:20px; text-align:center;">
            <button id="btn-open-editor" class="button-primary" style="width: auto; padding: 10px 20px;">
                <i class="fa-solid fa-wand-magic-sparkles"></i> プライバシー加工して口コミ投稿
            </button>
        </div>
    </div>

    <!-- Image Privacy Editor Modal -->
    <div id="privacy-editor-modal" class="modal-overlay">
        <div class="editor-container">
            <div class="editor-header">
                <h3>安心プライバシー加工</h3>
                <span class="close-editor-btn" style="font-size:24px; cursor:pointer;">&times;</span>
            </div>
            <div class="editor-canvas-wrapper">
                <canvas id="privacy-canvas"></canvas>
            </div>
            <div class="editor-tools">
                <div class="tool-row">
                    <button class="tool-btn active" id="tool-stamp" onclick="selectTool('stamp')">
                        <i class="fa-regular fa-face-smile"></i>
                        スタンプ
                    </button>
                    <button class="tool-btn" id="tool-blur" onclick="selectTool('blur')">
                        <i class="fa-solid fa-wand-magic-sparkles"></i>
                        ぼかし
                    </button>
                    <button class="tool-btn" id="tool-undo" onclick="undoCanvas()">
                        <i class="fa-solid fa-rotate-left"></i>
                        戻す
                    </button>
                </div>
                <!-- Stamp Selector -->
                <div id="stamp-options" class="stamp-selector">
                    <div class="stamp-option selected" onclick="selectStamp('🙂')">🙂</div>
                    <div class="stamp-option" onclick="selectStamp('💖')">💖</div>
                    <div class="stamp-option" onclick="selectStamp('⭐')">⭐</div>
                    <div class="stamp-option" onclick="selectImageStamp('./img/YHDlogo2.png')">
                        <img src="./img/YHDlogo2.png" style="width:24px; height:24px; object-fit:contain;">
                    </div>
                    <div class="stamp-option" onclick="selectImageStamp('./diagnosis/images/stamp.png')">
                        <img src="./diagnosis/images/stamp.png" style="width:24px; height:24px; object-fit:contain;">
                    </div>
                    <label class="stamp-option" style="cursor:pointer;">
                        <input type="file" id="custom-stamp-input" accept="image/*" style="display:none;"
                            onchange="handleCustomStamp(this)">
                        <i class="fa-regular fa-image"></i>
                    </label>
                </div>
                <div id="stamp-size-control"
                    style="display:none; width: 100%; padding: 10px; align-items: center; justify-content: space-between;">
                    <span style="font-size: 0.8em; color: #666;">サイズ調整:</span>
                    <input type="range" id="stamp-size-slider" min="0.5" max="3.0" step="0.1" value="1.0"
                        style="flex-grow: 1; margin-left: 10px;" oninput="updateStampSize(this.value)">
                </div>
            </div>
            <div class="editor-actions">
                <button class="btn-cancel" onclick="closeEditor()">キャンセル</button>
                <button class="btn-save" onclick="saveEditedImage()">保存して次へ</button>
            </div>
        </div>
    </div>

    <!-- Review Guide Modal -->
    <div id="review-guide-modal" class="modal-overlay">
        <div class="editor-container" style="height: auto; max-height:80vh; overflow-y:auto;">
            <div class="editor-header">
                <h3>口コミ投稿の準備</h3>
                <span class="close-review-btn" style="font-size:24px; cursor:pointer;"
                    onclick="closeReviewModal()">&times;</span>
            </div>
            <div class="review-guide">
                <div class="review-step" id="step-save-image" style="text-align:center; background:#e0f7fa;">
                    <strong style="color:#0ABAB5; font-size:1.1rem;">STEP 1: 画像を保存</strong>
                    <p style="font-size:0.9rem; margin:10px 0;">下の画像を<strong>長押し</strong>して「写真に保存」してください。</p>
                    <img id="review-generated-image" src=""
                        style="max-width:100%; border-radius:8px; border:2px solid #ccc; display:block; margin:0 auto;">
                    <p style="font-size:0.8rem; color:#666; margin-top:5px;">※確実に保存できるURLを発行済みです。</p>
                </div>
                <div class="review-step">
                    <div class="step-num">2</div>
                    <strong>コメントを作成＆コピー</strong>
                    <textarea id="review-comment-input" class="copy-input" rows="3"
                        placeholder="例：カラーがとても気に入りました！"></textarea>
                    <button class="button-secondary" onclick="copyComment()"
                        style="width:100%; font-weight:bold; margin-top:5px;">
                        <i class="fa-regular fa-copy"></i> コメントをコピー
                    </button>
                </div>
                <div class="review-step">
                    <div class="step-num">3</div>
                    <strong>Googleマップへ移動</strong>
                    <p style="font-size:0.9rem; margin-top:5px; text-align: left;">
                        開いた画面で ① クチコミを選択 ② 星(★)をタップ ③ コメントを貼り付け ④ 画像を添付して投稿！
                    </p>
                </div>
                <button class="button-primary" onclick="goToGoogleMaps()">
                    <i class="fa-brands fa-google"></i> Googleマップを開く
                </button>
                <button class="button-secondary" onclick="closeReviewModal()"
                    style="margin-top:10px; border:none; text-decoration:underline;">閉じる</button>
            </div>
        </div>
    </div>

    <script type="module" src="./mypage.js"></script>
</body>

</html>
</file>

