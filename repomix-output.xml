    margin-left: 0.25rem;
}

/* ★★★ 修正点: モーダルのスタイルを全体的に見直し ★★★ */
.modal {
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    /* モーダル背景の不透明度を 0.85 から 0.95 に上げて、奥を見えにくくする */
    background-color: rgba(0, 0, 0, 0.95);
    padding: 1rem;
    box-sizing: border-box;
    overflow-y: auto;
    display: none;
    /* Initially hidden */
    justify-content: center;
    align-items: flex-start;
}

.modal-content {
    background-color: var(--white-color);
    padding: 0;
    border-radius: 12px;
    width: 100%;
    max-width: 600px;
