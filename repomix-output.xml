<file path="storage.rules">
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // --- Helper Functions ---
    function isAdmin() {
      // リクエストしているユーザーが管理者権限を持っているか確認
      return request.auth != null && request.auth.token.admin == true;
    }

    // ★★★ 修正: 顧客のマイページ用ギャラリールール ★★★
    // AI診断アプリ(顧客本人)と管理アプリ(管理者)の両方からアクセスできるようにする
    match /users/{userId}/gallery/{allPaths=**} {
      // 読み書き: 顧客本人 または 管理者
      allow read, write: if request.auth.uid == userId || isAdmin();
    }
    
    // Diagnosis temporary uploads (Legacy/Other)
    match /uploads/{userId}/{allPaths=**} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }
    
    // AI Matching App Uploads
    match /ai-matching-uploads/{allPaths=**} {
      allow read, write: if true; 
    }

    // AI Matching App Results
    match /ai-matching-results/{allPaths=**} {
      allow read, write: if true;
    }
    // ⚠️ 注意: 以下のパスは認証なしでアクセス可能（開発用）
    // 本番運用時は request.auth != null のチェックを追加してください
    match /ai-analysis/{allPaths=**} {
      allow read, write: if true;
    }
    match /ai-matching-uploads/{allPaths=**} {
      allow read, write: if true;
    }
    match /ai-matching-results/{allPaths=**} {
      allow read, write: if true;
    }
    match /guest_uploads/{allPaths=**} {
      allow read, write: if true;
    }
    match /hair_app_uploads/{allPaths=**} {
      allow read, write: if true;
    }
    match /pc_generated/{allPaths=**} {
      allow read, write: if true;
    }
    // ★★★ 修正ここまで ▲▲▲★★★

    // ★★★ 修正: 口コミ用の一時画像保存パス ★★★
    match /temp_reviews/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // ★★★ 修正ここまで ▲▲▲★★★

    // --- (参考) 古いルールパス ---
    // 他の機能で使われている可能性を考慮し、残しておきます
    match /galleries/{userId}/{allPaths=**} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if isAdmin();
    }
    match /diagnoses/{diagnosesId}/{allPaths=**} {
       allow read, write: if isAdmin() || request.auth.uid == diagnosesId;
    }
  }
}
</file>

<file path="public/admin/style.css">
/* 基本設定と変数 */
:root {
    --primary-color: #3bb2b8;
    /* ティファニーブルー */
    --secondary-color: #F0FDF4;
    --accent-color: #ffc107;
    --text-color: #333;
    --light-text-color: #666;
    --background-color: #F8F9FA;
    --border-color: #E0E0E0;
    --white-color: #FFFFFF;
    --danger-color: #ffc1cc;
