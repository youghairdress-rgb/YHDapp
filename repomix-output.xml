    margin: 1.5rem 0 0.5rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
}

.gallery-grid-group {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 0.5rem;
}

.gallery-grid-group img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.2s;
    border: 1px solid var(--border-color);
}

.gallery-grid-group img:hover {
    transform: scale(1.05);
}

/* ★★★ 修正点: `image-viewer`のスタイルをユーザーサイド専用に定義 ★★★ */
.image-viewer {
    display: none;
    position: fixed;
    z-index: 2000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.9);
    justify-content: center;
    align-items: center;
    flex-direction: column;
    /* 画像の下にボタンを配置するために追加 */
    padding: 1rem;
    box-sizing: border-box;
}

.close-viewer {
    position: absolute;
    top: 15px;
    right: 35px;
    color: #f1f1f1;
    font-size: 40px;
    font-weight: bold;
    cursor: pointer;
    line-height: 1;
}

.image-viewer-content {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
}

/* --- Image Privacy Editor & Review Modal --- */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 2000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
}

.modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
}

.editor-container {
    background: white;
    width: 95%;
    max-width: 500px;
    height: 90vh;
    /* Max height for mobile */
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
}

.editor-header {
    padding: 15px;
    background: #f8f9fa;
    border-bottom: 1px solid #ddd;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.editor-header h3 {
    margin: 0;
    font-size: 1.1rem;
    color: #333;
}

.editor-canvas-wrapper {
    flex: 1;
    background: #333;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    position: relative;
}

canvas#privacy-canvas {
    max-width: 100%;
    max-height: 100%;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
}

.editor-tools {
    padding: 10px;
    background: #fff;
    border-top: 1px solid #ddd;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.tool-row {
    display: flex;
    justify-content: space-around;
    gap: 10px;
}

.tool-btn {
    flex: 1;
    padding: 10px;
    border: 1px solid #ddd;
    background: #f8f9fa;
    border-radius: 8px;
    font-size: 0.9rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    transition: all 0.2s;
}

.tool-btn.active {
    background: #e6f7ff;
    border-color: #1890ff;
    color: #1890ff;
}

.tool-btn i {
    font-size: 1.2rem;
}

.stamp-selector {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding: 5px 0;
    border-top: 1px dashed #eee;
    margin-top: 5px;
}

.stamp-option {
    font-size: 2rem;
    cursor: pointer;
    padding: 5px;
    border: 2px solid transparent;
    border-radius: 5px;
}

.stamp-option.selected {
    background: #e6f7ff;
    border-color: #1890ff;
}

.editor-actions {
    padding: 15px;
    background: #fff;
    border-top: 1px solid #eee;
    display: flex;
    gap: 10px;
}

.btn-cancel {
    flex: 1;
    padding: 12px;
    border: 1px solid #ddd;
    background: #fff;
    border-radius: 8px;
    color: #666;
    font-weight: bold;
}

.btn-save {
    flex: 2;
    padding: 12px;
    border: none;
    background: #0ABAB5;
    color: white;
    border-radius: 8px;
    font-weight: bold;
}

/* Review Step Styles */
.review-guide {
    padding: 20px;
    text-align: center;
}

.review-step {
    margin-bottom: 20px;
    text-align: left;
    background: #f9f9f9;
    padding: 15px;
    border-radius: 8px;
}

.step-num {
    display: inline-block;
    width: 24px;
    height: 24px;
    background: #0ABAB5;
    color: white;
    border-radius: 50%;
    text-align: center;
    line-height: 24px;
    margin-right: 10px;
    font-weight: bold;
}

.copy-area {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}

.copy-input {
    flex: 1;
    padding: 8px;
    border: 1px solid #ddd;
    border-radius: 4px;
    background: #fff;
}

/* ▼▼▼ 新規追加: アップロード中オーバーレイ ▼▼▼ */
.uploading-overlay {
    display: none;
    position: fixed;
    z-index: 2001;
    /* 画像ビューアより手前 */
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(255, 255, 255, 0.8);
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 1rem;
    color: var(--text-color);
}

/* ▲▲▲ 新規追加ここまで ▲▲▲ */

/* --- ▲▲▲ マイページ関連のスタイルここまで ▲▲▲ --- */
