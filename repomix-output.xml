  // 日計集計リスナー (reservationTime 基準に変更)
  const listenToDailySales = () => {
    const startOfDay = new Date(today); // today は adminMain の冒頭で 00:00:00 に設定済み
    const endOfDay = new Date(today);
    endOfDay.setHours(23, 59, 59, 999);

