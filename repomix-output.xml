/* --- Phase 5 & 5-2: 2-Column Responsive Layout (DELL 23" optimized) --- */
.p5-layout-2col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: auto 1fr auto;
  /* Middle row fills space to push footer down */
  grid-template-areas:
    'header header'
    'left right'
    'footer footer';
