/* layout.css - Optimized Landscape Architecture for 1920x1080 */

:root {
  --side-gap: 50px;
  --card-padding: 60px;
}

/* Phase Container Base */
.phase-container {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background-color: #f1f5f9;
  box-sizing: border-box;
  padding: var(--side-gap);
  z-index: 50;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.phase-container.active {
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 1;
}

/* Landscape Card Structure */
.landscape-card {
  width: 100%;
  height: 100%;
  max-width: 1760px;
  max-height: 960px;
  background-color: #fff;
  border-radius: 40px;
  padding: 30px 40px;
  /* Reduced from var(--card-padding) */
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  border: 1px solid #e2e8f0;
}

/* Phase 1: Opening (More balanced 50/50 split and Centered) */
.p1-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  width: 100%;
  max-width: 1400px;
  /* Constrain width to center the content area */
  height: 100%;
  align-items: center;
  margin: 0 auto;
  /* Center the entire block in the viewport */
}

.p1-left {
  display: flex;
  justify-content: flex-end;
  /* Push logo towards center */
  padding-right: 60px;
}

.p1-logo {
  width: 520px;
  height: 520px;
  border-radius: 50%;
  object-fit: cover;
  box-shadow: 0 40px 80px rgba(0, 0, 0, 0.1);
  border: 12px solid #fff;
}

.p1-right {
  padding-left: 60px;
  display: flex;
  justify-content: flex-start;
  /* Push text towards center */
}

/* Phase 2: Profile (Grid Layout) */
.p2-layout {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  grid-template-rows: auto 1fr;
  gap: 40px 80px;
  height: 100%;
}

.p2-header {
  grid-column: 1 / span 2;
}

.p2-left {
  display: flex;
  flex-direction: column;
  gap: 40px;
  justify-content: flex-start;
}

.p2-right {
  display: flex;
  flex-direction: column;
  gap: 40px;
}

.p2-footer {
  margin-top: auto;
  padding-top: 40px;
  display: flex;
  justify-content: center;
  /* Center the button in left column */
}

/* Phase 3: Materials (5-Column Center) */
.p3-layout {
  display: flex;
  flex-direction: column;
  height: 100%;
  width: 100%;
}

.p3-header {
  margin-bottom: 50px;
}

.p3-grid-5 {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 30px;
  flex: 1;
  align-items: center;
}

.p3-footer {
  margin-top: 60px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 60px;
}

.p3-actions-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15px;
}

/* Phase 3.5: AI Loading (2-column Rich Layout) */
.p35-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  width: 100%;
  max-width: 1400px;
  height: 100%;
  align-items: center;
  margin: 0 auto;
}

.p35-left {
  display: flex;
  justify-content: flex-end;
  padding-right: 80px;
}

.p35-logo {
  width: 480px;
  height: 480px;
  border-radius: 50%;
  object-fit: cover;
  box-shadow: 0 40px 80px rgba(0, 0, 0, 0.1);
  border: 12px solid #fff;
  animation: pulseLogo 3s infinite ease-in-out;
}

.p35-right {
  padding-left: 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}

.spinner-large {
  width: 120px;
  height: 120px;
  border: 12px solid rgba(45, 212, 191, 0.1);
  border-top: 12px solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 40px;
}

.p35-status-group {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.p35-title {
  font-size: 64px;
  font-weight: 800;
  color: #000;
  margin: 0;
  line-height: 1.2;
}

.p35-subtitle {
  font-size: 28px;
  color: #64748b;
  font-weight: 500;
  margin: 0;
}

/* Phase 4: Diagnosis Results (Ideal 2x2 Landscape Balance) */
#phase4 .landscape-card {
  padding: 20px 60px 25px;
  /* Reduced vertical card padding further */
}

.p4-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: auto 1fr 1fr auto;
  gap: 1vh 3vw;
  /* Tighter gap */
  height: 100%;
  max-height: calc(100vh - 100px);
  /* Use more screen height */
}

.p4-header {
  grid-column: 1 / span 2;
  margin-bottom: 0.5vh;
}

.result-section.no-margin {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  padding: 0.5vh 1.5vw;
  /* Tighter internal padding */
  display: flex;
  flex-direction: column;
  height: 100%;
  box-sizing: border-box;
}

.result-title-center {
  font-size: clamp(16px, 2.2vh, 22px);
  font-weight: 800;
  text-align: center;
  margin-bottom: 0.5vh;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
  color: var(--dark-color);
}

.result-grid-split {
  display: flex;
  flex-direction: column;
  gap: 0.5vh;
  /* Tighter line spacing */
  flex: 1;
  min-height: 0;
}

/* Vertical Stacking for Content but Horizontal Split for Label/Value */
.result-item {
  display: grid !important;
  grid-template-columns: 140px 1fr !important;
  /* Shift value further right */
  align-items: flex-start !important;
  gap: 10px !important;
  padding: 0 !important;
  background: transparent !important;
}

.result-item-label {
  font-size: clamp(12px, 1.4vh, 15px) !important;
  font-weight: 700 !important;
